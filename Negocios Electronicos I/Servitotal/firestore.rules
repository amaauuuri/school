rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Funciones Auxiliares ────────────────────────────────────────────────
    
    // Verifica si la solicitud viene de un usuario autenticado
    function isAuthed() {
      return request.auth != null;
    }

    // Verifica si el usuario es el dueño/admin del restaurante
    function isRestaurantOwner(restaurantId) {
      return isAuthed() && request.auth.uid == restaurantId;
    }

    // Verifica si el usuario autenticado pertenece al restaurante (Admin o Staff)
    function belongsToRestaurant(restaurantId) {
      return isAuthed() && (
        request.auth.uid == restaurantId ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.restaurantId == restaurantId
        )
      );
    }

    // ─── Perfiles de Usuario ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
      allow read: if isAuthed();
    }

    // ─── 1. RESTAURANTES e INVENTARIO ───────────────────────────────────────
    // 'restaurants/{restaurantId}': Datos del local, nombre, dirección, duenoUid, configuración de mesas.
    // 'restaurants/{restaurantId}/menu': Platos (id, nombre, descripción, precio, categoría, disponible)
    match /restaurants/{restaurantId} {
      allow read, write: if belongsToRestaurant(restaurantId);

      match /menu/{itemId} {
        allow read: if belongsToRestaurant(restaurantId);
        allow write: if belongsToRestaurant(restaurantId);
      }
    }

    // ─── 2. OPERACIÓN EN TIEMPO REAL (Mesas y Comandas) ──────────────────────
    // 'orders_global/{orderId}': Comandas globales (restaurantId, mesaNumero, status, items, totalAmount, createdAt, poolStaff)
    // Permite lectura y creación pública si contiene un 'restaurantId' válido (para apps externas en el futuro).
    // Actualización y borrado restringidos a personal autenticado del restaurante.
    match /orders_global/{orderId} {
      allow read: if (resource != null && resource.data.restaurantId != null) ||
                     (request.resource != null && request.resource.data.restaurantId != null) ||
                     isAuthed();

      allow create: if request.resource.data.restaurantId != null;

      allow update, delete: if isAuthed();
    }

    // ─── 3. MÉTRICAS E HISTORIAL (Admin Panel) ──────────────────────────────
    // 'sales_history/{saleId}': Registro histórico inmutable de comandas con status 'pagado'.
    match /sales_history/{saleId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if false; // Inmutable para preservar la integridad de los reportes
    }
  }
}
